#!/data/data/com.termux/files/usr/bin/bash
set -eu
if [ "$#" -lt 1 ]; then printf 'usage: codex-learn <lesson>\n' >&2; exit 2; fi
RUNTIME_ROOT="${CODEX_RUNTIME_ROOT:?CODEX_RUNTIME_ROOT is required}"
LESSON_DIR="$RUNTIME_ROOT/memory"
LESSON_FILE="$LESSON_DIR/lessons.md"
mkdir -p "$LESSON_DIR"
printf -- '- %s\n' "$*" >> "$LESSON_FILE"
printf 'lesson-recorded:%s\n' "$LESSON_FILE"
